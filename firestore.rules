rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper verifying if incoming client request IP complies with permitted laboratory addresses
    function getSchool(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId));
    }

    // Rules governing exam attempts
    match /attempts/{attemptId} {
      allow create, update, read, write: if true;
    }

    // Error books logging
    match /error_books/{entryId} {
      allow create, update, read, write: if true;
    }

    // Generic development & student link access permissions
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
